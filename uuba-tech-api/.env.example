DATABASE_URL=postgresql+asyncpg://uuba:uuba@localhost:5432/uuba
API_KEY=uuba-dev-key-change-me
ENVIRONMENT=development
DEBUG=true

# Unkey (auth provider) — desabilitado por default em dev
UNKEY_ENABLED=false
TESTING=0

# LGPD: periodos de retencao (anos)
RETENCAO_FATURAS_ANOS=5
RETENCAO_MENSAGENS_ANOS=2
RETENCAO_CLIENTES_INATIVOS_ANOS=5

# Cofre de credenciais (AES-256-GCM) — obrigatorio para integrations
UUBA_ENCRYPTION_KEY=

# Webhooks (opcional em dev)
ASAAS_WEBHOOK_SECRET=
WHATSAPP_VERIFY_TOKEN=
